            <mlIntentUtterances>
                <utterance>Where is my case</utterance>
            </mlIntentUtterances>
            <mlIntentUtterances>
                <utterance>What&apos;s happening with case</utterance>
            </mlIntentUtterances>
            <mlIntentUtterances>
                <utterance>Case number status</utterance>
            </mlIntentUtterances>
            <mlIntentUtterances>
                <utterance>I want to know about my case</utterance>
            </mlIntentUtterances>
            <mlIntentUtterances>
                <utterance>Tell me about case</utterance>
