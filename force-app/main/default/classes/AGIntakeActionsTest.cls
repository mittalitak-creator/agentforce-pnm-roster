    // ========== CreateAGCaseAction Tests ==========
    
    @isTest
    static void testCreateAGCase_Appeal_Success() {
        Account member = [SELECT Id, Member_Id__c FROM Account WHERE Member_Id__c = 'MEM001' LIMIT 1];
        
        CreateAGCaseAction.AGCaseRequest request = new CreateAGCaseAction.AGCaseRequest();
        request.accountId = member.Id;
        request.memberId = member.Member_Id__c;
        request.agType = 'Appeal';
        request.appealType = 'Part D Drug - Formulary';
        request.lob = 'Medicare Advantage';
        request.reason = 'Drug not covered on formulary, requesting exception';
        request.isUrgent = false;
        
        Test.startTest();
        List<CreateAGCaseAction.AGCaseResult> results = 
            CreateAGCaseAction.createAGCase(new List<CreateAGCaseAction.AGCaseRequest>{ request });
        Test.stopTest();
        
        System.assertEquals(1, results.size(), 'Should return one result');
        CreateAGCaseAction.AGCaseResult result = results[0];
        System.assertEquals(true, result.success, 'Case creation should succeed');
        System.assertNotEquals(null, result.caseId, 'Case ID should be populated');
        System.assertNotEquals(null, result.caseNumber, 'Case number should be populated');
        System.assertEquals('New', result.status, 'Status should be New');
        
        // Verify case was created correctly
        Case createdCase = [SELECT Id, AG_Type__c, Appeal_Type__c, Member_Id__c FROM Case WHERE Id = :result.caseId];
        System.assertEquals('Appeal', createdCase.AG_Type__c, 'AG Type should be Appeal');
        System.assertEquals('Part D Drug - Formulary', createdCase.Appeal_Type__c, 'Appeal type should match');
    }
    
