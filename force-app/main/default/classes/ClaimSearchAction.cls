/**
 * @description Apex Action for Agentforce to search and retrieve claim information
 * @author Generated by Cursor AI for A&G Intake
 */
public with sharing class ClaimSearchAction {
    
    /**
     * @description Search for claims by Claim Number, Member ID, or Status
     * @param requests List of search requests
     * @return List of search results with claim information
     */
    @InvocableMethod(
        label='Search Claim'
        description='Searches for claims by Claim Number, Member ID, or Status'
        category='A&G Intake'
    )
    public static List<ClaimSearchResult> searchClaim(List<ClaimSearchRequest> requests) {
        List<ClaimSearchResult> results = new List<ClaimSearchResult>();
        
        if (requests == null || requests.isEmpty()) {
            ClaimSearchResult errorResult = new ClaimSearchResult();
            errorResult.success = false;
            errorResult.errorMessage = 'No search criteria provided';
            results.add(errorResult);
            return results;
        }
        
        for (ClaimSearchRequest request : requests) {
            results.add(processClaimSearch(request));
        }
        
        return results;
    }
    
    /**
     * @description Process individual claim search request
     * @param request The search request
     * @return Claim search result
     */
    private static ClaimSearchResult processClaimSearch(ClaimSearchRequest request) {
        ClaimSearchResult result = new ClaimSearchResult();
        
        try {
            List<Claim__c> claims = new List<Claim__c>();
            
            // Build dynamic SOQL query with proper bind variables
            String query = 'SELECT Id, Name, Claim_Type__c, Claim_Status__c, Claim_Amount__c, ' +
                          'Paid_Amount__c, Service_Date__c, Finalized_Date__c, Denial_Reason__c, ' +
                          'Provider_Name__c, Service_Description__c, Member__c, Member__r.Member_Id__c, ' +
                          'Member__r.FirstName, Member__r.LastName, Related_Case__c, Related_Case__r.CaseNumber ' +
                          'FROM Claim__c WHERE ';
            
            List<String> conditions = new List<String>();
            
            // Search by Claim Number if provided (highest priority)
            if (String.isNotBlank(request.claimNumber)) {
                conditions.add('Name = \'' + String.escapeSingleQuotes(request.claimNumber) + '\'');
            }
            
            // Search by Member ID if provided
            if (String.isNotBlank(request.memberId)) {
                conditions.add('Member__r.Member_Id__c = \'' + String.escapeSingleQuotes(request.memberId) + '\'');
            }
            
            // Filter by Claim Status if provided
            if (String.isNotBlank(request.claimStatus)) {
                conditions.add('Claim_Status__c = \'' + String.escapeSingleQuotes(request.claimStatus) + '\'');
            }
            
            // Filter by Claim Type if provided
            if (String.isNotBlank(request.claimType)) {
                conditions.add('Claim_Type__c = \'' + String.escapeSingleQuotes(request.claimType) + '\'');
            }
            
            if (conditions.isEmpty()) {
                result.success = false;
                result.errorMessage = 'Please provide at least one search criterion (Claim Number, Member ID, Status, or Type)';
                return result;
            }
            
            // Join conditions with AND
            query += String.join(conditions, ' AND ');
            query += ' ORDER BY CreatedDate DESC LIMIT 10';
            
            claims = Database.query(query);
            
            if (claims.isEmpty()) {
                result.success = false;
                result.errorMessage = 'No claims found matching the search criteria';
                result.claimsFound = 0;
                return result;
            }
            
            // Return first claim found (or all if multiple)
            Claim__c claim = claims[0];
            result.success = true;
            result.claimId = claim.Id;
            result.claimNumber = claim.Name;
            result.claimType = claim.Claim_Type__c;
            result.claimStatus = claim.Claim_Status__c;
            result.claimAmount = claim.Claim_Amount__c;
            result.paidAmount = claim.Paid_Amount__c;
            result.serviceDate = claim.Service_Date__c;
            result.finalizedDate = claim.Finalized_Date__c;
            result.denialReason = claim.Denial_Reason__c;
            result.providerName = claim.Provider_Name__c;
            result.serviceDescription = claim.Service_Description__c;
            result.claimsFound = claims.size();
            
            // Member information
            if (claim.Member__c != null) {
                result.memberId = claim.Member__r.Member_Id__c;
                result.memberName = claim.Member__r.FirstName + ' ' + claim.Member__r.LastName;
            }
            
            // Related case information
            if (claim.Related_Case__c != null) {
                result.relatedCaseId = claim.Related_Case__c;
                result.relatedCaseNumber = claim.Related_Case__r.CaseNumber;
            }
            
            // Build summary message
            if (claims.size() == 1) {
                result.message = 'Found claim ' + claim.Name + ' (' + claim.Claim_Type__c + ' - ' + claim.Claim_Status__c + ')';
            } else {
                result.message = 'Found ' + claims.size() + ' claims. Showing first match: ' + claim.Name;
                result.additionalClaimsInfo = buildAdditionalClaimsInfo(claims);
            }
            
        } catch (QueryException qe) {
            result.success = false;
            result.errorMessage = 'Error searching for claim: ' + qe.getMessage();
        } catch (Exception e) {
            result.success = false;
            result.errorMessage = 'Unexpected error: ' + e.getMessage();
        }
        
        return result;
    }
    
    /**
     * @description Build summary of additional claims found
     * @param claims List of claims found
     * @return Formatted string with claim summaries
     */
    private static String buildAdditionalClaimsInfo(List<Claim__c> claims) {
        List<String> claimSummaries = new List<String>();
        
        for (Integer i = 0; i < Math.min(claims.size(), 5); i++) {
            Claim__c c = claims[i];
            claimSummaries.add(c.Name + ' (' + c.Claim_Type__c + ' - ' + c.Claim_Status__c + ')');
        }
        
        return String.join(claimSummaries, '; ');
    }
    
