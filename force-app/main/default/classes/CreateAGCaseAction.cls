/**
 * @description Apex Action for Agentforce to create A&G Cases
 * @author Generated by Cursor AI for A&G Intake
 */
public without sharing class CreateAGCaseAction {
    
    /**
     * @description Create an Appeal or Grievance case
     * @param requests List of case creation requests
     * @return List of case creation results
     */
    @InvocableMethod(
        label='Create A&G Case'
        description='Creates an Appeals & Grievances case with member and request details'
        category='A&G Intake'
    )
    public static List<AGCaseResult> createAGCase(List<AGCaseRequest> requests) {
        List<AGCaseResult> results = new List<AGCaseResult>();
        
        if (requests == null || requests.isEmpty()) {
            AGCaseResult errorResult = new AGCaseResult();
            errorResult.success = false;
            errorResult.errorMessage = 'No case creation request provided';
            results.add(errorResult);
            return results;
        }
        
        for (AGCaseRequest request : requests) {
            results.add(processAGCaseCreation(request));
        }
        
        return results;
    }
    
    /**
     * @description Process individual case creation request
     * @param request The case creation request
     * @return Case creation result
     */
    private static AGCaseResult processAGCaseCreation(AGCaseRequest request) {
        AGCaseResult result = new AGCaseResult();
        
        try {
            // Validation
            if (String.isBlank(request.accountId)) {
                result.success = false;
                result.errorMessage = 'Member Account ID is required';
                return result;
            }
            
            if (String.isBlank(request.agType)) {
                result.success = false;
                result.errorMessage = 'A&G Type (Appeal or Grievance) is required';
                return result;
            }
            
            if (String.isBlank(request.reason)) {
                result.success = false;
                result.errorMessage = 'Reason for request is required';
                return result;
            }
            
            // Create the Case
            Case agCase = new Case();
            agCase.AccountId = request.accountId;
            agCase.Subject = request.agType + ' - ' + (request.appealType != null ? request.appealType : request.grievanceType);
            agCase.Description = request.reason;
            agCase.Origin = 'Agentforce Chat';
            agCase.Status = 'New';
            agCase.Priority = request.isUrgent ? 'High' : 'Medium';
            
            // Set custom fields
            agCase.put('AG_Type__c', request.agType);
            agCase.put('Member_Id__c', request.memberId);
            agCase.put('LOB__c', request.lob);
            agCase.put('Reason_For_Request__c', request.reason);
            agCase.put('Organization_Received_Date__c', DateTime.now());
            
            if (request.agType == 'Appeal' && String.isNotBlank(request.appealType)) {
                agCase.put('Appeal_Type__c', request.appealType);
            }
            
            if (request.agType == 'Grievance' && String.isNotBlank(request.grievanceType)) {
                agCase.put('Grievance_Type__c', request.grievanceType);
            }
            
            insert agCase;
            
            // Query back to get case number
            Case createdCase = [
                SELECT Id, CaseNumber, Subject, Status, Priority, CreatedDate
                FROM Case
                WHERE Id = :agCase.Id
                LIMIT 1
            ];
            
            result.success = true;
            result.caseId = createdCase.Id;
            result.caseNumber = createdCase.CaseNumber;
            result.status = createdCase.Status;
            result.priority = createdCase.Priority;
            result.createdDate = createdCase.CreatedDate;
            result.message = generateSuccessMessage(createdCase, request);
            
        } catch (DmlException de) {
            result.success = false;
            result.errorMessage = 'Error creating case: ' + de.getMessage();
        } catch (Exception e) {
            result.success = false;
            result.errorMessage = 'Unexpected error: ' + e.getMessage();
        }
        
        return result;
    }
    
    /**
     * @description Generate success message for case creation
     * @param caseRecord The created case
     * @param request The original request
     * @return Formatted success message
     */
    private static String generateSuccessMessage(Case caseRecord, AGCaseRequest request) {
        String message = request.agType + ' case created successfully!\n\n';
        message += 'Case Number: ' + caseRecord.CaseNumber + '\n';
        message += 'Status: ' + caseRecord.Status + '\n';
        message += 'Priority: ' + caseRecord.Priority + '\n';
        message += 'Created: ' + caseRecord.CreatedDate.format() + '\n\n';
        
        if (request.isUrgent) {
            message += '⚠️ This case has been marked as URGENT and will be prioritized.\n\n';
        }
        
        message += 'Next steps:\n';
        message += '• You will receive a confirmation email shortly\n';
        message += '• The case will be reviewed by our team\n';
        message += '• You can check the status anytime using case number ' + caseRecord.CaseNumber;
        
        return message;
    }
    
    /**
     * @description Input wrapper for AG case creation request
     */
    public class AGCaseRequest {
        @InvocableVariable(label='Account ID' description='Member Account ID' required=true)
        public Id accountId;
        
        @InvocableVariable(label='Member ID' description='Member ID')
        public String memberId;
        
        @InvocableVariable(label='A&G Type' description='Appeal or Grievance' required=true)
        public String agType;
        
        @InvocableVariable(label='Appeal Type' description='Type of appeal (if Appeal)')
        public String appealType;
        
        @InvocableVariable(label='Grievance Type' description='Type of grievance (if Grievance)')
        public String grievanceType;
        
        @InvocableVariable(label='Line of Business' description='LOB (Medicare Advantage, Part D, etc.)')
        public String lob;
        
        @InvocableVariable(label='Reason' description='Reason for the appeal or grievance' required=true)
        public String reason;
        
        @InvocableVariable(label='Is Urgent' description='Whether this is an urgent/expedited request')
        public Boolean isUrgent = false;
    }
    
    /**
     * @description Output wrapper for AG case creation result
     */
    public class AGCaseResult {
        @InvocableVariable(label='Success' description='Whether case creation was successful')
        public Boolean success;
        
        @InvocableVariable(label='Error Message' description='Error message if creation failed')
        public String errorMessage;
        
        @InvocableVariable(label='Message' description='Success message with case details')
        public String message;
        
        @InvocableVariable(label='Case ID' description='Salesforce Case ID')
        public Id caseId;
        
        @InvocableVariable(label='Case Number' description='Case number')
        public String caseNumber;
        
        @InvocableVariable(label='Status' description='Case status')
        public String status;
        
        @InvocableVariable(label='Priority' description='Case priority')
        public String priority;
        
        @InvocableVariable(label='Created Date' description='When the case was created')
        public DateTime createdDate;
    }
}
