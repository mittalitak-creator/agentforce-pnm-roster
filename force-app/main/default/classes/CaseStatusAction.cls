        public String errorMessage;
        
        @InvocableVariable(label='Status Message' description='Friendly status message')
        public String statusMessage;
        
        @InvocableVariable(label='Case ID' description='Salesforce ID of the case')
        public Id caseId;
        
        @InvocableVariable(label='Case Number' description='Case number')
        public String caseNumber;
        
        @InvocableVariable(label='Status' description='Current status of the case')
        public String status;
        
        @InvocableVariable(label='Subject' description='Case subject')
        public String subject;
        
        @InvocableVariable(label='Priority' description='Case priority')
        public String priority;
        
        @InvocableVariable(label='Description' description='Case description')
        public String description;
        
        @InvocableVariable(label='Created Date' description='When the case was created')
        public DateTime createdDate;
        
        @InvocableVariable(label='Closed Date' description='When the case was closed')
        public DateTime closedDate;
        
