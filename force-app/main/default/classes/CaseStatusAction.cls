        public String contactEmail;
        
        @InvocableVariable(label='Contact Phone' description='Phone of the contact')
        public String contactPhone;
        
        @InvocableVariable(label='Is Closed' description='Whether the case is closed')
        public Boolean isClosed;
        
        @InvocableVariable(label='Is Escalated' description='Whether the case is escalated')
        public Boolean isEscalated;
        
        @InvocableVariable(label='Case Reason' description='Reason for the case')
        public String caseReason;
        
        @InvocableVariable(label='Case Type' description='Type of the case')
        public String caseType;
        
        @InvocableVariable(label='Origin' description='Origin of the case')
        public String origin;
    }
}
