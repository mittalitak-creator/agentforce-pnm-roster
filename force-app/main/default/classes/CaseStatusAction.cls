/**
 * @description Apex Action for Agentforce to query case status information
 * @author Generated by Cursor AI
 */
public with sharing class CaseStatusAction {
    
    /**
     * @description Get case status by case number
     * @param caseNumber The case number to query
     * @return CaseStatusResult containing case details
     */
    @InvocableMethod(
        label='Get Case Status'
        description='Retrieves the current status and details of a case by case number'
        category='Case Management'
    )
    public static List<CaseStatusResult> getCaseStatus(List<CaseStatusRequest> requests) {
        List<CaseStatusResult> results = new List<CaseStatusResult>();
        
        if (requests == null || requests.isEmpty()) {
            CaseStatusResult errorResult = new CaseStatusResult();
            errorResult.success = false;
            errorResult.errorMessage = 'No case number provided';
            results.add(errorResult);
            return results;
        }
        
        for (CaseStatusRequest request : requests) {
            results.add(processCaseStatusRequest(request));
        }
        
        return results;
    }
    
    /**
     * @description Process individual case status request
     * @param request The case status request
     * @return CaseStatusResult with case information
     */
    private static CaseStatusResult processCaseStatusRequest(CaseStatusRequest request) {
        CaseStatusResult result = new CaseStatusResult();
        
        try {
            if (String.isBlank(request.caseNumber)) {
                result.success = false;
                result.errorMessage = 'Case number is required';
                return result;
            }
            
            // Query case with related information
            List<Case> cases = [
                SELECT Id, CaseNumber, Status, Subject, Priority, 
                       Description, CreatedDate, ClosedDate, 
                       Owner.Name, Contact.Name, Contact.Email, Contact.Phone,
                       IsClosed, IsEscalated, Reason, Type, Origin
                FROM Case 
                WHERE CaseNumber = :request.caseNumber 
                LIMIT 1
            ];
            
            if (cases.isEmpty()) {
                result.success = false;
                result.errorMessage = 'Case not found with number: ' + request.caseNumber;
                return result;
            }
            
            Case caseRecord = cases[0];
            
            // Populate result
            result.success = true;
            result.caseId = caseRecord.Id;
            result.caseNumber = caseRecord.CaseNumber;
            result.status = caseRecord.Status;
            result.subject = caseRecord.Subject;
            result.priority = caseRecord.Priority;
            result.description = caseRecord.Description;
            result.createdDate = caseRecord.CreatedDate;
            result.closedDate = caseRecord.ClosedDate;
            result.ownerName = caseRecord.Owner.Name;
            result.isClosed = caseRecord.IsClosed;
            result.isEscalated = caseRecord.IsEscalated;
            result.caseReason = caseRecord.Reason;
            result.caseType = caseRecord.Type;
            result.origin = caseRecord.Origin;
            
            if (caseRecord.Contact != null) {
                result.contactName = caseRecord.Contact.Name;
                result.contactEmail = caseRecord.Contact.Email;
                result.contactPhone = caseRecord.Contact.Phone;
            }
            
            // Generate friendly status message
            result.statusMessage = generateStatusMessage(caseRecord);
            
        } catch (QueryException qe) {
            result.success = false;
            result.errorMessage = 'Error querying case: ' + qe.getMessage();
        } catch (Exception e) {
            result.success = false;
            result.errorMessage = 'Unexpected error: ' + e.getMessage();
        }
        
        return result;
    }
    
    /**
     * @description Generate a friendly status message for the case
     * @param caseRecord The case record
     * @return Formatted status message
     */
    private static String generateStatusMessage(Case caseRecord) {
        String message = 'Case ' + caseRecord.CaseNumber + ' is currently ' + caseRecord.Status;
        
        if (caseRecord.IsClosed) {
            message += ' (Closed';
            if (caseRecord.ClosedDate != null) {
                message += ' on ' + caseRecord.ClosedDate.format();
            }
            message += ')';
        } else {
            if (caseRecord.IsEscalated) {
                message += ' and has been escalated';
            }
            message += '. Priority: ' + caseRecord.Priority;
        }
        
        if (String.isNotBlank(caseRecord.Subject)) {
            message += '. Subject: ' + caseRecord.Subject;
        }
        
        return message;
    }
    
    /**
     * @description Input wrapper for case status request
     */
    public class CaseStatusRequest {
        @InvocableVariable(label='Case Number' description='The case number to look up' required=true)
        public String caseNumber;
    }
    
