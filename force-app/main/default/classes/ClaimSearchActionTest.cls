    @isTest
    static void testSearchByClaimNumber_Success() {
        // Get test claim
        Claim__c testClaim = [SELECT Name FROM Claim__c WHERE Claim_Type__c = 'Pharmacy' LIMIT 1];
        
        // Create search request
        ClaimSearchAction.ClaimSearchRequest request = new ClaimSearchAction.ClaimSearchRequest();
        request.claimNumber = testClaim.Name;
        
        Test.startTest();
        List<ClaimSearchAction.ClaimSearchResult> results = ClaimSearchAction.searchClaim(
            new List<ClaimSearchAction.ClaimSearchRequest>{ request }
        );
        Test.stopTest();
        
        // Verify results
        System.assertEquals(1, results.size(), 'Should return one result');
        ClaimSearchAction.ClaimSearchResult result = results[0];
        System.assertEquals(true, result.success, 'Search should be successful');
        System.assertEquals(testClaim.Name, result.claimNumber, 'Should return correct claim number');
        System.assertEquals('Pharmacy', result.claimType, 'Should return correct claim type');
        System.assertEquals('Denied', result.claimStatus, 'Should return correct status');
        System.assertEquals(500.00, result.claimAmount, 'Should return correct amount');
        System.assertNotEquals(null, result.denialReason, 'Should have denial reason');
        System.assertNotEquals(null, result.relatedCaseNumber, 'Should have related case');
    }
    
