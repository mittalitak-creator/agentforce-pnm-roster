/**
 * @description Apex Action for Agentforce to search and retrieve prior authorization information
 * @author Generated by Cursor AI for A&G Intake
 */
public with sharing class PriorAuthSearchAction {
    
    /**
     * @description Search for prior auths by Authorization Reference Identifier or Member ID
     * @param requests List of search requests
     * @return List of search results with prior auth information
     */
    @InvocableMethod(
        label='Search Prior Auth'
        description='Searches for prior authorizations by Auth ID or Member ID'
        category='A&G Intake'
    )
    public static List<PriorAuthSearchResult> searchPriorAuth(List<PriorAuthSearchRequest> requests) {
        List<PriorAuthSearchResult> results = new List<PriorAuthSearchResult>();
        
        if (requests == null || requests.isEmpty()) {
            PriorAuthSearchResult errorResult = new PriorAuthSearchResult();
            errorResult.success = false;
            errorResult.errorMessage = 'No search criteria provided';
            results.add(errorResult);
            return results;
        }
        
        for (PriorAuthSearchRequest request : requests) {
            results.add(processPriorAuthSearch(request));
        }
        
        return results;
    }
    
    /**
     * @description Process individual prior auth search request
     * @param request The search request
     * @return Prior auth search result
     */
    private static PriorAuthSearchResult processPriorAuthSearch(PriorAuthSearchRequest request) {
        PriorAuthSearchResult result = new PriorAuthSearchResult();
        
        try {
            List<CareRequest> priorAuths = new List<CareRequest>();
            
            // Build dynamic SOQL query
            String query = 'SELECT Id, Name, Authorization_Reference_Identifier__c, MemberIdentificationNumber, ' +
                          'MemberStatus, ReferenceCaseNumber, CreatedDate ' +
                          'FROM CareRequest WHERE RecordType.DeveloperName = \'PriorAuth\' AND ';
            
            List<String> conditions = new List<String>();
            
            // Search by Authorization Reference Identifier if provided
            if (String.isNotBlank(request.authorizationId)) {
                conditions.add('Authorization_Reference_Identifier__c = \'' + String.escapeSingleQuotes(request.authorizationId) + '\'');
            }
            
            // Search by Member ID if provided
            if (String.isNotBlank(request.memberId)) {
                conditions.add('MemberIdentificationNumber = \'' + String.escapeSingleQuotes(request.memberId) + '\'');
            }
            
            // Filter by Status if provided
            if (String.isNotBlank(request.status)) {
                conditions.add('MemberStatus = \'' + String.escapeSingleQuotes(request.status) + '\'');
            }
            
            if (conditions.isEmpty()) {
                result.success = false;
                result.errorMessage = 'Please provide at least one search criterion (Authorization ID, Member ID, or Status)';
                return result;
            }
            
            // Join conditions with AND
            query += String.join(conditions, ' AND ');
            query += ' ORDER BY CreatedDate DESC LIMIT 10';
            
            priorAuths = Database.query(query);
            
            if (priorAuths.isEmpty()) {
                result.success = false;
                result.errorMessage = 'No prior authorizations found matching the search criteria';
                result.priorAuthsFound = 0;
                return result;
            }
            
            // Return first prior auth found
            CareRequest priorAuth = priorAuths[0];
            result.success = true;
            result.careRequestId = priorAuth.Id;
            result.careRequestName = priorAuth.Name;
            result.authorizationId = priorAuth.Authorization_Reference_Identifier__c;
            result.memberId = priorAuth.MemberIdentificationNumber;
            result.status = priorAuth.MemberStatus;
            result.referenceCaseNumber = priorAuth.ReferenceCaseNumber;
            result.createdDate = priorAuth.CreatedDate;
            result.priorAuthsFound = priorAuths.size();
            
            // Build summary message
            if (priorAuths.size() == 1) {
                result.message = 'Found prior auth ' + priorAuth.Authorization_Reference_Identifier__c + ' (Status: ' + priorAuth.MemberStatus + ')';
            } else {
                result.message = 'Found ' + priorAuths.size() + ' prior auths. Showing first match: ' + priorAuth.Authorization_Reference_Identifier__c;
                result.additionalPriorAuthsInfo = buildAdditionalPriorAuthsInfo(priorAuths);
            }
            
        } catch (QueryException qe) {
            result.success = false;
            result.errorMessage = 'Error searching for prior auth: ' + qe.getMessage();
        } catch (Exception e) {
            result.success = false;
            result.errorMessage = 'Unexpected error: ' + e.getMessage();
        }
        
        return result;
    }
    
    /**
     * @description Build summary of additional prior auths found
     * @param priorAuths List of prior auths found
     * @return Formatted string with prior auth summaries
     */
    private static String buildAdditionalPriorAuthsInfo(List<CareRequest> priorAuths) {
        List<String> priorAuthSummaries = new List<String>();
        
        for (Integer i = 0; i < Math.min(priorAuths.size(), 5); i++) {
            CareRequest pa = priorAuths[i];
            priorAuthSummaries.add(pa.Authorization_Reference_Identifier__c + ' (' + pa.MemberStatus + ')');
        }
        
        return String.join(priorAuthSummaries, '; ');
    }
    
    /**
     * @description Input wrapper for prior auth search request
     */
    public class PriorAuthSearchRequest {
        @InvocableVariable(label='Authorization ID' description='The authorization reference identifier to search for')
        public String authorizationId;
        
        @InvocableVariable(label='Member ID' description='Search prior auths by member ID')
        public String memberId;
        
        @InvocableVariable(label='Status' description='Filter by prior auth status')
        public String status;
    }
    
    /**
     * @description Output wrapper for prior auth search result
     */
    public class PriorAuthSearchResult {
        @InvocableVariable(label='Success' description='Whether the search was successful')
        public Boolean success;
        
        @InvocableVariable(label='Error Message' description='Error message if search failed')
        public String errorMessage;
        
        @InvocableVariable(label='Message' description='Result message')
        public String message;
        
        @InvocableVariable(label='Prior Auths Found' description='Number of prior auths found')
        public Integer priorAuthsFound;
        
        @InvocableVariable(label='Care Request ID' description='Salesforce Care Request Record ID')
        public Id careRequestId;
        
        @InvocableVariable(label='Care Request Name' description='Care Request Name')
        public String careRequestName;
        
        @InvocableVariable(label='Authorization ID' description='Authorization Reference Identifier')
        public String authorizationId;
        
        @InvocableVariable(label='Member ID' description='Associated member ID')
        public String memberId;
        
        @InvocableVariable(label='Status' description='Prior auth status')
        public String status;
        
        @InvocableVariable(label='Reference Case Number' description='Related case number')
        public String referenceCaseNumber;
        
        @InvocableVariable(label='Created Date' description='Date prior auth was created')
        public DateTime createdDate;
        
        @InvocableVariable(label='Additional Prior Auths Info' description='Summary of other prior auths found')
        public String additionalPriorAuthsInfo;
    }
}
