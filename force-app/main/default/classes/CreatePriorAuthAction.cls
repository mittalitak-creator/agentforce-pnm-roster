/**
 * @description Apex Action to create Prior Authorization records
 * @author Generated by Cursor AI for A&G Intake
 */
public class CreatePriorAuthAction {
    
    @InvocableMethod(
        label='Create Prior Auth'
        description='Creates a prior authorization record on CareRequest'
        category='A&G Intake'
    )
    public static List<PriorAuthResult> createPriorAuth(List<PriorAuthRequest> requests) {
        List<PriorAuthResult> results = new List<PriorAuthResult>();
        List<CareRequest> priorAuthsToInsert = new List<CareRequest>();
        
        // Get Prior Auth Record Type
        Id priorAuthRecordTypeId = Schema.SObjectType.CareRequest.getRecordTypeInfosByDeveloperName()
            .get('Prior_Auth').getRecordTypeId();
        
        for (PriorAuthRequest req : requests) {
            CareRequest newPriorAuth = new CareRequest();
            newPriorAuth.RecordTypeId = priorAuthRecordTypeId;
            
            if (req.caseId != null) {
                newPriorAuth.CareRequestCaseId = req.caseId;
            }
            
            if (req.name != null) {
                newPriorAuth.Name = req.name;
            }
            
            if (req.memberId != null) {
                newPriorAuth.MemberId = req.memberId;
            }
            
            if (req.memberIdentificationNumber != null) {
                newPriorAuth.MemberIdentificationNumber = req.memberIdentificationNumber;
            }
            
            if (req.authorizationId != null) {
                newPriorAuth.Authorization_Reference_Identifier__c = req.authorizationId;
            }
            
            if (req.status != null) {
                newPriorAuth.MemberStatus = req.status;
            }
            
            if (req.organizationReceivedDate != null) {
                newPriorAuth.Organization_Received_Date__c = req.organizationReceivedDate;
            }
            
            priorAuthsToInsert.add(newPriorAuth);
        }
        
        try {
            insert priorAuthsToInsert;
            
            List<CareRequest> createdPriorAuths = [
                SELECT Id, Name, Authorization_Reference_Identifier__c, MemberStatus, 
                       MemberIdentificationNumber
                FROM CareRequest 
                WHERE Id IN :priorAuthsToInsert
            ];
            
            for (CareRequest pa : createdPriorAuths) {
                PriorAuthResult result = new PriorAuthResult();
                result.success = true;
                result.priorAuthId = pa.Id;
                result.priorAuthName = pa.Name;
                result.authorizationId = pa.Authorization_Reference_Identifier__c;
                result.status = pa.MemberStatus;
                result.message = 'Prior Auth ' + pa.Authorization_Reference_Identifier__c + ' created successfully';
                results.add(result);
            }
            
        } catch (DmlException e) {
            PriorAuthResult result = new PriorAuthResult();
            result.success = false;
            result.message = 'Error creating prior auth: ' + e.getMessage();
            results.add(result);
        }
        
        return results;
    }
    
    public class PriorAuthRequest {
        @InvocableVariable(required=true label='Case ID')
        public Id caseId;
        
        @InvocableVariable(required=true label='Name')
        public String name;
        
        @InvocableVariable(required=true label='Member ID (Account)')
        public Id memberId;
        
        @InvocableVariable(required=true label='Member Identification Number')
        public String memberIdentificationNumber;
        
        @InvocableVariable(required=true label='Authorization ID')
        public String authorizationId;
        
        @InvocableVariable(required=true label='Status')
        public String status;
        
        @InvocableVariable(label='Organization Received Date')
        public DateTime organizationReceivedDate;
    }
    
    public class PriorAuthResult {
        @InvocableVariable
        public Boolean success;
        
        @InvocableVariable
        public String message;
        
        @InvocableVariable
        public Id priorAuthId;
        
        @InvocableVariable
        public String priorAuthName;
        
        @InvocableVariable
        public String authorizationId;
        
        @InvocableVariable
        public String status;
    }
}
