/**
 * @description Apex Action for Agentforce to search and identify members
 * @author Generated by Cursor AI for A&G Intake
 */
public without sharing class MemberSearchAction {
    
    /**
     * @description Search for member by Member ID or Name + DOB
     * @param requests List of search requests
     * @return List of search results with member information
     */
    @InvocableMethod(
        label='Search Member'
        description='Searches for a member by Member ID or Name and Date of Birth'
        category='A&G Intake'
    )
    public static List<MemberSearchResult> searchMember(List<MemberSearchRequest> requests) {
        List<MemberSearchResult> results = new List<MemberSearchResult>();
        
        if (requests == null || requests.isEmpty()) {
            MemberSearchResult errorResult = new MemberSearchResult();
            errorResult.success = false;
            errorResult.errorMessage = 'No search criteria provided';
            results.add(errorResult);
            return results;
        }
        
        for (MemberSearchRequest request : requests) {
            results.add(processMemberSearch(request));
        }
        
        return results;
    }
    
    /**
     * @description Process individual member search request
     * @param request The search request
     * @return Member search result
     */
    private static MemberSearchResult processMemberSearch(MemberSearchRequest request) {
        MemberSearchResult result = new MemberSearchResult();
        
        try {
            List<Account> members = new List<Account>();
            
            // Search by Member ID if provided
            if (String.isNotBlank(request.memberId)) {
                members = [
                    SELECT Id, FirstName, LastName, PersonBirthdate, PersonEmail, 
                           Phone, PersonMailingStreet, PersonMailingCity, PersonMailingState,
                           PersonMailingPostalCode, Member_Id__c,
                           (SELECT Id, Plan.LineOfBusiness FROM MemberPlans WHERE Status = 'Active' AND PrimarySecondaryTertiary = 'Primary' LIMIT 1)
                    FROM Account
                    WHERE IsPersonAccount = true 
                    AND Member_Id__c = :request.memberId
                    LIMIT 1
                ];
            }
            // Search by Name + DOB if Member ID not provided
            else if (String.isNotBlank(request.firstName) && 
                     String.isNotBlank(request.lastName) && 
                     request.dateOfBirth != null) {
                members = [
                    SELECT Id, FirstName, LastName, PersonBirthdate, PersonEmail, 
                           Phone, PersonMailingStreet, PersonMailingCity, PersonMailingState,
                           PersonMailingPostalCode, Member_Id__c,
                           (SELECT Id, Plan.LineOfBusiness FROM MemberPlans WHERE Status = 'Active' AND PrimarySecondaryTertiary = 'Primary' LIMIT 1)
                    FROM Account
                    WHERE IsPersonAccount = true 
                    AND FirstName = :request.firstName
                    AND LastName = :request.lastName
                    AND PersonBirthdate = :request.dateOfBirth
                    LIMIT 5
                ];
            } else {
                result.success = false;
                result.errorMessage = 'Please provide either Member ID or First Name + Last Name + Date of Birth';
                return result;
            }
            
            if (members.isEmpty()) {
                result.success = false;
                result.errorMessage = 'No member found matching the search criteria';
                result.membersFound = 0;
                return result;
            }
            
            // Return first member found
            Account member = members[0];
            result.success = true;
            result.memberId = member.Member_Id__c;
            result.accountId = member.Id;
            result.firstName = member.FirstName;
            result.lastName = member.LastName;
            result.dateOfBirth = member.PersonBirthdate;
            result.email = member.PersonEmail;
            result.phone = member.Phone;
            result.address = formatAddress(member);
            result.membersFound = members.size();
            
            // Get Line of Business from primary active Member Plan
            if (!member.MemberPlans.isEmpty() && member.MemberPlans[0].Plan != null) {
                result.lineOfBusiness = member.MemberPlans[0].Plan.LineOfBusiness;
            }
            
            if (members.size() > 1) {
                result.message = 'Multiple members found. Showing first match. Please verify member details.';
            } else {
                result.message = 'Member found successfully';
            }
            
        } catch (QueryException qe) {
            result.success = false;
            result.errorMessage = 'Error searching for member: ' + qe.getMessage();
        } catch (Exception e) {
            result.success = false;
            result.errorMessage = 'Unexpected error: ' + e.getMessage();
        }
        
        return result;
    }
    
    /**
     * @description Format address from account record
     * @param member The member account
     * @return Formatted address string
     */
    private static String formatAddress(Account member) {
        List<String> addressParts = new List<String>();
        
        if (String.isNotBlank(member.PersonMailingStreet)) {
            addressParts.add(member.PersonMailingStreet);
        }
        if (String.isNotBlank(member.PersonMailingCity)) {
            addressParts.add(member.PersonMailingCity);
        }
        if (String.isNotBlank(member.PersonMailingState)) {
            addressParts.add(member.PersonMailingState);
        }
        if (String.isNotBlank(member.PersonMailingPostalCode)) {
            addressParts.add(member.PersonMailingPostalCode);
        }
        
        return String.join(addressParts, ', ');
    }
    
    /**
     * @description Input wrapper for member search request
     */
    public class MemberSearchRequest {
        @InvocableVariable(label='Member ID' description='The member ID to search for')
        public String memberId;
        
        @InvocableVariable(label='First Name' description='Member first name')
        public String firstName;
        
        @InvocableVariable(label='Last Name' description='Member last name')
        public String lastName;
        
        @InvocableVariable(label='Date of Birth' description='Member date of birth')
        public Date dateOfBirth;
    }
    
    /**
     * @description Output wrapper for member search result
     */
    public class MemberSearchResult {
        @InvocableVariable(label='Success' description='Whether the search was successful')
        public Boolean success;
        
        @InvocableVariable(label='Error Message' description='Error message if search failed')
        public String errorMessage;
        
        @InvocableVariable(label='Message' description='Result message')
        public String message;
        
        @InvocableVariable(label='Account ID' description='Salesforce Account ID')
        public Id accountId;
        
        @InvocableVariable(label='Member ID' description='Member ID')
        public String memberId;
        
        @InvocableVariable(label='First Name' description='Member first name')
        public String firstName;
        
        @InvocableVariable(label='Last Name' description='Member last name')
        public String lastName;
        
        @InvocableVariable(label='Date of Birth' description='Member date of birth')
        public Date dateOfBirth;
        
        @InvocableVariable(label='Email' description='Member email')
        public String email;
        
        @InvocableVariable(label='Phone' description='Member phone')
        public String phone;
        
        @InvocableVariable(label='Address' description='Member address')
        public String address;
        
        @InvocableVariable(label='Line of Business' description='Member Line of Business from active plan')
        public String lineOfBusiness;
        
        @InvocableVariable(label='Members Found' description='Number of members found')
        public Integer membersFound;
    }
}
